#!/bin/bash

echo "🧹 Starting system cleanup..."

# 1. Clean pacman cache (keep last 2 versions)
echo "📦 Cleaning pacman cache..."
sudo paccache -r

# 2. Remove orphan packages
echo "🧼 Removing orphan packages..."
orphans=$(pacman -Qtdq)

if [ -n "$orphans" ]; then
    sudo pacman -Rns $orphans
else
    echo "No orphan packages found."
fi

# 3. Clean yay cache
echo "📦 Cleaning AUR cache..."
yay -Sc --noconfirm

# 4. Clean journal logs (keep last 7 days)
echo "🗒️ Cleaning journal logs..."
sudo journalctl --vacuum-time=7d

# 5. Clear user cache
echo "🗑️ Clearing ~/.cache..."
rm -rf ~/.cache/*

# 6. Clear trash
echo "🧺 Emptying trash..."
rm -rf ~/.local/share/Trash/*

echo "✅ Cleanup complete!"
